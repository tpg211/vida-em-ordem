# Strava OAuth — get credentials at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/auth/strava/callback
PORT=3001

# Garmin Connect (optional — for Garmin integration)
GARMIN_EMAIL=your_garmin_email
GARMIN_PASSWORD=your_garmin_password

# Vercel Blob — get from Vercel dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=your_blob_token

# Sync secret — any random string to protect the upload endpoint
SYNC_SECRET=change_me_to_any_random_string

# Your Vercel deployment URL (no https://)
VERCEL_URL=your-app.vercel.app
